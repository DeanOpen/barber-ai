# Optional fallback if no key is set in /admin (shop mode only)
OPENAI_API_KEY=

# Initial admin password (only used to seed data/settings.json on first run)
ADMIN_PASSWORD=change-me

# PUBLIC_SHOWCASE mode (build-time flag).
#   "1" → fully client-side, bring-your-own-key demo:
#         - /admin and /api/admin/* disabled (410 Gone)
#         - /api/generate* disabled (410 Gone)
#         - the browser calls OpenAI directly with a key the user pastes in
#         - key + settings persisted only in browser localStorage
#         - data/settings.json is never written
#   ""  → normal kiosk / shop mode (server holds the key, /admin is live)
# IMPORTANT: this is a Next.js NEXT_PUBLIC_* var so it is inlined at build
# time. To switch modes you must rebuild (or rebuild the Docker image).
NEXT_PUBLIC_SHOWCASE=
