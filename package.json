{
  "name": "barber-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.9.1",
  "scripts": {
    "dev": "next dev",
    "dev:showcase": "NEXT_PUBLIC_SHOWCASE=1 next dev",
    "build": "next build && opennextjs-cloudflare build --skipNextBuild",
    "build:next": "next build",
    "build:showcase": "NEXT_PUBLIC_SHOWCASE=1 next build",
    "build:showcase:cf": "NEXT_PUBLIC_SHOWCASE=1 next build && NEXT_PUBLIC_SHOWCASE=1 opennextjs-cloudflare build --skipNextBuild",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:only": "opennextjs-cloudflare deploy",
    "deploy:full": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "deploy:showcase": "NEXT_PUBLIC_SHOWCASE=1 opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "preview:showcase": "NEXT_PUBLIC_SHOWCASE=1 opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "start": "next start",
    "start:showcase": "NEXT_PUBLIC_SHOWCASE=1 next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@ant-design/cssinjs": "^1.24.0",
    "@ant-design/icons": "^5.5.2",
    "@ant-design/nextjs-registry": "^1.0.2",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@opennextjs/cloudflare": "^1.19.4",
    "antd": "^5.23.0",
    "next": "15.5.15",
    "openai": "^4.77.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5",
    "wrangler": "^4.85.0"
  }
}
